{
  "name": "korg-nano-kontrol2",
  "version": "0.3.0",
  "description": "Node.js/Browser library for KORG nanoKONTROL and nanoKONTROL2",
  "type": "module",
  "main": "lib/korg-nano-kontrol2.cjs",
  "module": "lib/korg-nano-kontrol2.mjs",
  "types": "lib/korg-nano-kontrol2.d.ts",
  "exports": {
    "require": "./lib/korg-nano-kontrol2.cjs",
    "import": "./lib/korg-nano-kontrol2.mjs"
  },
  "files": [
    "lib",
    "CHAGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:ts": "tsc",
    "build:rollup": "rollup -c",
    "build": "pnpm run clean && pnpm run typecheck && pnpm run build:ts && pnpm run build:rollup",
    "buildSample": "pnpm run typecheckSample && pnpm run build:ts && rollup -c samples/browser/rollup.config.js && rollup -c samples/node/rollup.config.js",
    "clean": "rm -rf lib",
    "format": "prettier --check src/*.ts src/**/*.ts test/*.ts",
    "format:fix": "prettier --write src/*.ts src/**/*.ts test/*.ts",
    "lint": "eslint src/*.ts src/**/*.ts test/*.ts",
    "lint:fix": "eslint src/*.ts src/**/*.ts test/*.ts --fix",
    "mocha": "pnpm run build && mocha --require tsx \"test/*.ts\"",
    "test": "pnpm run lint && pnpm run format && pnpm run mocha",
    "typecheck": "tsc -p tsconfig.json && tsc -p test/tsconfig.json",
    "typecheckSample": "tsc -p samples/browser/tsconfig.json && tsc -p samples/node/tsconfig.json",
    "watch": "tsc -w"
  },
  "keywords": [
    "midi",
    "korg",
    "nanoKONTROL"
  ],
  "author": "Shinichiro Takata <7912032+tkt182@users.noreply.github.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chai": "^5.2.3",
    "@types/jquery": "^4.0.1",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "chai": "^6.2.2",
    "eslint": "^10.5.0",
    "jquery": "^4.0.0",
    "jzz": "^1.9.6",
    "mocha": "^11.7.6",
    "prettier": "^3.8.4",
    "rollup": "^4.62.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/debug": "^4.1.13",
    "debug": "^4.4.3",
    "eventemitter2": "^6.4.9",
    "lodash": "^4.18.1",
    "webmidi": "^3.1.16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkt182/korg-nano-kontrol2.git"
  },
  "bugs": {
    "url": "https://github.com/tkt182/korg-nano-kontrol2/issues"
  },
  "homepage": "https://github.com/tkt182/korg-nano-kontrol2#readme"
}
